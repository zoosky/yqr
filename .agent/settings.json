{
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(git:status)",
      "Bash(git:diff:*)",
      "Bash(git:log:*)",
      "Bash(git:branch:*)",
      "Bash(git:checkout:*)",
      "Bash(git:add:*)",
      "Bash(git:commit:*)",
      "Bash(git:push:*)",
      "Bash(gh:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh run view:*)",
      "Bash(gh pr merge:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "deny": [
      "Bash(rm:-rf:*)",
      "Bash(git:push:origin:main)",
      "Bash(git:push:-u:origin:main)",
      "Bash(git:push:--force:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.agent/hooks/notify-sound.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "env": {
    "RUST_BACKTRACE": "1",
    "CARGO_TERM_COLOR": "always"
  }
}